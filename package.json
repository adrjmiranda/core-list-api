{
  "name": "core-list-api",
  "version": "1.0.0",
  "description": "**CoreList API** is a high-performance, multi-tenant contact management system designed for scalability and data integrity. This project serves as a cornerstone of my professional portfolio, demonstrating advanced Node.js patterns and a commitment to code quality.",
  "scripts": {
    "dev": "tsx watch src/shared/infra/http/server.ts",
    "build": "tsup src",
    "start": "node dist/server.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adrjmiranda/core-list-api.git"
  },
  "keywords": [],
  "author": "Adriano Miranda",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/adrjmiranda/core-list-api/issues"
  },
  "homepage": "https://github.com/adrjmiranda/core-list-api#readme",
  "dependencies": {
    "@prisma/client": "^7.4.1",
    "bcrypt": "^6.0.0",
    "fastify": "^5.7.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prisma": "^7.4.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
