{
  "name": "core-list-api",
  "version": "1.0.0",
  "description": "**CoreList API** is a high-performance, multi-tenant contact management system designed for scalability and data integrity. This project serves as a cornerstone of my professional portfolio, demonstrating advanced Node.js patterns and a commitment to code quality.",
  "scripts": {
    "dev": "tsx watch src/shared/infra/http/server.ts",
    "build": "tsup src/shared/infra/http/server.ts --format esm --clean --minify",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "db:push": "tsx node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "tsx node_modules/drizzle-kit/bin.cjs studio",
    "db:generate": "tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx node_modules/drizzle-kit/bin.cjs migrate",
    "compose:test:up": "docker compose -f docker-compose.test.yml up -d",
    "compose:test:down": "docker compose -f docker-compose.test.yml down",
    "test": "npx dotenv-cli -e .env.test -- node --import tsx --test 'src/**/*.{test,spec}.ts'",
    "test:watch": "nodemon --watch src -e ts --exec npm run test",
    "test:init": "npm run compose:test:up && npm run db:test:push && npx dotenv-cli -e .env.test -- node --import tsx --test 'src/**/*.spec.ts'",
    "db:test:push": "npx dotenv-cli -e .env.test -- npm run db:push",
    "db:test:studio": "npx dotenv-cli -e .env.test -- npm run db:studio",
    "db:test:generate": "npx dotenv-cli -e .env.test -- npm run db:generate",
    "db:test:migrate": "npx dotenv-cli -e .env.test -- npm run db:migrate"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adrjmiranda/core-list-api.git"
  },
  "keywords": [],
  "author": "Adriano Miranda",
  "license": "MIT",
  "type": "module",
  "imports": {
    "#/*": {
      "types": "./src/*.ts",
      "default": "./dist/*.js"
    }
  },
  "bugs": {
    "url": "https://github.com/adrjmiranda/core-list-api/issues"
  },
  "homepage": "https://github.com/adrjmiranda/core-list-api#readme",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@sentry/node": "^10.42.0",
    "@types/mime-types": "^3.0.1",
    "bcrypt": "^6.0.0",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.7.4",
    "mime-types": "^3.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "pg": "^8.19.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.3.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}
