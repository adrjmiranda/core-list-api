{
	"compilerOptions": {
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"esModuleInterop": true,

		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"outDir": "./dist",
		"rootDir": "./src",
		"strict": true,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"noUnusedLocals": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,

		"typeRoots": ["./node_modules/@types", "./src/@types"],

		/* Path aliases */
		"baseUrl": ".",
		"paths": {
			"#/*": ["src/*"]
		}
	},
	"include": ["src/**/*"]
}
